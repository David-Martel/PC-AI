{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"version": "2.1.0",
	"providers": {
		"pcai-inference": {
			"enabled": true,
			"baseUrl": "http://127.0.0.1:8080",
			"defaultModel": "pcai-inference",
			"timeout": 120000
		},
		"pcai-native": {
			"enabled": true,
			"type": "ffi",
			"backend": "llamacpp",
			"modelPath": "Models/Qwen2.5-3B-Instruct-GGUF/Qwen2.5-3B-Instruct-Q4_K_M.gguf",
			"gpuLayers": -1,
			"defaultTemperature": 0.7,
			"defaultMaxTokens": 2048
		},
		"functiongemma": {
			"enabled": true,
			"baseUrl": "http://127.0.0.1:8000",
			"defaultModel": "functiongemma-270m-it",
			"timeout": 120000
		},
		"ollama": {
			"enabled": true,
			"baseUrl": "http://127.0.0.1:11434",
			"defaultModel": "llama3.2:latest",
			"timeout": 120000
		},
		"lmstudio": {
			"enabled": true,
			"baseUrl": "http://127.0.0.1:1234",
			"defaultModel": "local-model",
			"timeout": 120000
		},
		"vllm": {
			"enabled": true,
			"baseUrl": "http://127.0.0.1:8001",
			"defaultModel": "vllm-model",
			"timeout": 120000
		}
	},
	"contextManagement": {
		"maxContextTokens": 16384,
		"reservedForResponse": 4096,
		"systemPromptFile": "DIAGNOSE.md",
		"decisionTreeFile": "DIAGNOSE_LOGIC.md",
		"chatPromptFile": "CHAT.md"
	},
	"router": {
		"enabled": true,
		"provider": "functiongemma",
		"baseUrl": "http://127.0.0.1:8000",
		"model": "functiongemma-270m-it",
		"toolsPath": "Config/pcai-tools.json",
		"disable": false,
		"force": false,
		"strict": false,
		"defaultTemperature": 0.2
	},
	"prompts": {
		"diagnosticAnalysis": {
			"temperature": 0.3,
			"maxTokens": 4096,
			"topP": 0.9
		},
		"optimization": {
			"temperature": 0.5,
			"maxTokens": 2048,
			"topP": 0.95
		}
	},
	"responseFormat": {
		"includeReasoningSteps": true,
		"structuredOutput": true,
		"markdownFormatting": true
	},
	"fallbackOrder": ["pcai-native", "pcai-inference"],
	"nativeInference": {
		"preferNative": true,
		"dllSearchPaths": [
			"bin/pcai_inference.dll",
			"Deploy/pcai-inference/target/release/pcai_inference.dll"
		],
		"runtimeBinarySelection": {
			"enabled": true,
			"autoDownload": false,
			"variants": [
				{
					"name": "cuda-sm120",
					"kind": "cuda",
					"minCompute": 120,
					"maxCompute": 129,
					"dllPath": "bin/prebuilt/cuda-sm120/pcai_inference.dll",
					"url": ""
				},
				{
					"name": "cuda-sm89",
					"kind": "cuda",
					"minCompute": 89,
					"maxCompute": 119,
					"dllPath": "bin/prebuilt/cuda-sm89/pcai_inference.dll",
					"url": ""
				},
				{
					"name": "cuda-sm86",
					"kind": "cuda",
					"minCompute": 86,
					"maxCompute": 88,
					"dllPath": "bin/prebuilt/cuda-sm86/pcai_inference.dll",
					"url": ""
				},
				{
					"name": "cuda-sm80",
					"kind": "cuda",
					"minCompute": 80,
					"maxCompute": 85,
					"dllPath": "bin/prebuilt/cuda-sm80/pcai_inference.dll",
					"url": ""
				},
				{
					"name": "cuda-sm75",
					"kind": "cuda",
					"minCompute": 75,
					"maxCompute": 79,
					"dllPath": "bin/prebuilt/cuda-sm75/pcai_inference.dll",
					"url": ""
				},
				{
					"name": "cpu-generic",
					"kind": "cpu",
					"dllPath": "bin/pcai_inference.dll",
					"url": ""
				}
			]
		},
		"backends": {
			"mistralrs": {
				"priority": 1,
				"description": "Rust mistral.rs backend (optimized for Mistral models)"
			},
			"llamacpp": {
				"priority": 2,
				"description": "llama-rs compatibility backend (GGML models, optional cuBLAS)",
				"settings": {
					"architecture": "llama",
					"n_ctx": 4096,
					"n_batch": 512,
					"n_gpu_layers": -1,
					"samplers": [
						"repetition:penalty=1.15:last_n=64",
						"topk:k=40",
						"topp:p=0.95",
						"temperature:0.7"
					],
					"seed": 42
				}
			}
		}
	},
	"evaluation": {
		"binSearchPaths": [
			"bin",
			"%USERPROFILE%/.local/bin",
			"Native/pcai_core/pcai_inference/target/release",
			"Deploy/pcai-inference/target/release"
		]
	}
}
