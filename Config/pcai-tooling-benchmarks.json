{
  "reportDirectory": "Reports/tooling-benchmarks",
  "defaultSuite": "default",
  "defaults": {
    "iterations": 5,
    "warmup": 1,
    "maxDepth": 3,
    "maxResults": 250,
    "filePattern": "*.ps1",
    "contentPattern": "function",
    "contentFilePattern": "*.ps1",
    "tokenSampleRepeat": 4000
  },
  "suites": {
    "quick": [
      "acceleration-import",
      "acceleration-stack",
      "acceleration-probe",
      "direct-core-probe",
      "token-estimate",
      "directory-manifest",
      "file-search",
      "runtime-config",
      "shared-cache-hit",
      "external-cache-status",
      "command-map",
      "network-discovery"
    ],
    "default": [
      "acceleration-import",
      "acceleration-stack",
      "acceleration-probe",
      "direct-core-probe",
      "token-estimate",
      "directory-manifest",
      "file-search",
      "content-search",
      "full-context",
      "runtime-config",
      "shared-cache-hit",
      "external-cache-status",
      "command-map",
      "network-discovery"
    ]
  },
  "cases": [
    {
      "id": "acceleration-import",
      "name": "Acceleration Module Import",
      "category": "Startup",
      "path": ".",
      "iterations": 3,
      "warmup": 1
    },
    {
      "id": "token-estimate",
      "name": "Token Estimate",
      "category": "Core",
      "path": "."
    },
    {
      "id": "acceleration-probe",
      "name": "Acceleration Probe",
      "category": "Startup",
      "path": "."
    },
    {
      "id": "acceleration-stack",
      "name": "Acceleration Stack Bootstrap",
      "category": "Startup",
      "path": "."
    },
    {
      "id": "direct-core-probe",
      "name": "Direct Core Probe",
      "category": "Startup",
      "path": "."
    },
    {
      "id": "directory-manifest",
      "name": "Directory Manifest",
      "category": "Search",
      "path": ".",
      "maxDepth": 3,
      "maxResults": 500
    },
    {
      "id": "file-search",
      "name": "File Search",
      "category": "Search",
      "path": ".",
      "filePattern": "*.ps1",
      "maxResults": 250
    },
    {
      "id": "content-search",
      "name": "Content Search",
      "category": "Search",
      "path": ".",
      "contentPattern": "function",
      "contentFilePattern": "*.ps1",
      "maxResults": 100
    },
    {
      "id": "full-context",
      "name": "Full Context",
      "category": "Diagnostics",
      "path": ".",
      "iterations": 3
    },
    {
      "id": "runtime-config",
      "name": "Runtime Config Cache",
      "category": "PowerShell",
      "path": "."
    },
    {
      "id": "shared-cache-hit",
      "name": "Shared Cache Hit",
      "category": "PowerShell",
      "path": "."
    },
    {
      "id": "external-cache-status",
      "name": "External Cache Status",
      "category": "PowerShell",
      "path": "."
    },
    {
      "id": "command-map",
      "name": "Command Map Cache",
      "category": "PowerShell",
      "path": "."
    },
    {
      "id": "thunderbolt-status",
      "name": "Thunderbolt status",
      "category": "network",
      "path": ".",
      "iterations": 3,
      "warmup": 1
    },
    {
      "id": "network-discovery",
      "name": "Network discovery",
      "category": "network",
      "path": ".",
      "iterations": 2,
      "warmup": 1
    }
  ]
}
