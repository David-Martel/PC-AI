--- Modules/PC-AI.Gpu/Public/Get-NvidiaSoftwareRegistry.ps1
+++ Modules/PC-AI.Gpu/Public/Get-NvidiaSoftwareRegistry.ps1
@@ -84,12 +84,21 @@
         }

         $raw      = [System.IO.File]::ReadAllText($RegistryPath)
-        $registry = $raw | ConvertFrom-Json
-
-        if (-not $registry.components) {
+        try {
+            $registry = $raw | ConvertFrom-Json
+        } catch {
+            Write-Error "Registry file is not valid JSON: $RegistryPath"
+            return $null
+        }
+
+        if ($null -eq $registry -or -not $registry.PSObject.Properties.Match('components').Count) {
             Write-Error "Registry file is missing the 'components' array: $RegistryPath"
             return $null
         }
+
+        if ($registry.components -isnot [array]) {
+            $registry.components = @($registry.components)
+        }

         # --- Apply filters to .components ---
         $filtered = @($registry.components)
